# RayConvo — Environment Variables
# Copy to .env and fill in values

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001

# ── OpenClaw Gateway ───────────────────────────────────────────────────────
# The OpenClaw gateway URL on your machine
OPENCLAW_GATEWAY=http://127.0.0.1:18789

# Your OpenClaw gateway token (from openclaw.json)
OPENCLAW_TOKEN=your_openclaw_token_here

# Which session to send messages to (usually 'main')
OPENCLAW_SESSION=main

# ── TTS (edge-tts — free, no API key needed) ───────────────────────────────
# Pick a voice: en-US-BrianNeural, en-US-AvaNeural, en-US-EmmaNeural, en-US-AndrewNeural
TTS_VOICE=en-US-BrianNeural
TTS_RATE=+0%

# ── STT (faster-whisper — runs locally, no config needed) ─────────────────
# Model size: tiny, base, small, medium, large-v3
WHISPER_MODEL=base
